# Copie este arquivo para .env.local e preencha os valores reais.
# Nunca commite o .env.local (já está no .gitignore).

# Supabase — Project Settings > API (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de service role — Project Settings > API > service_role (secreta).
# Usada pela rota /api/admin/usuarios para convidar novos usuários
# (auth.admin.inviteUserByEmail). Nunca expor ao client.
SUPABASE_SERVICE_ROLE_KEY=
# URL pública do app (usada nos links de e-mail de convite/recuperação de
# senha). Em produção, a URL do deploy na Vercel; em dev, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter — alternativa gratuita à OpenAI só para teste do pipeline de
# copy (https://openrouter.ai/keys). Se OPENAI_API_KEY estiver vazia e esta
# estiver preenchida, o sistema usa OpenRouter automaticamente — não precisa
# mexer em código. Para forçar um dos dois mesmo com as duas chaves
# presentes, defina AI_PROVIDER=openai ou AI_PROVIDER=openrouter.
OPENROUTER_API_KEY=
# AI_PROVIDER=
# Modelos gratuitos do OpenRouter (sufixo ":free") usados por padrão — troque
# se o modelo padrão sair do catálogo grátis ou vier rate-limitado 429
# (catálogo muda com frequência e modelos populares saturam sob carga
# compartilhada; conferir disponibilidade em
# https://openrouter.ai/models?max_price=0).
# OPENROUTER_MODEL_ROUTINE=openai/gpt-oss-20b:free
# OPENROUTER_MODEL_LAUNCH=openai/gpt-oss-20b:free

# Zernio — https://zernio.com/signup (crie a conta, conecte @puzzlerecordss,
# gere a chave em zernio.com/dashboard). Formato da chave: sk_ + 64 hex.
ZERNIO_API_KEY=
# URL base da API do Zernio — já confirmada contra a doc real em
# docs.zernio.com (auditoria do M12), não precisa preencher a menos que o
# Zernio forneça um ambiente de staging/sandbox diferente do padrão.
# ZERNIO_API_BASE_URL=https://zernio.com/api/v1

# Google Drive API — OAuth 2.0 Client ID (Google Cloud Console > APIs e
# serviços > Credenciais > Criar credenciais > ID do cliente OAuth, tipo
# "Web application"). GOOGLE_OAUTH_REDIRECT_URI precisa bater exatamente com
# uma das "Authorized redirect URIs" cadastradas no client
# (http://localhost:3000/admin/integracoes/callback em dev).
# GOOGLE_OAUTH_REFRESH_TOKEN fica vazia até você completar o fluxo em
# /admin/integracoes (só admin) — a tela mostra o valor uma única vez.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/admin/integracoes/callback
GOOGLE_OAUTH_REFRESH_TOKEN=
# ID da pasta do Google Drive usada pelo agente (parte final da URL da pasta)
GOOGLE_DRIVE_FOLDER_ID=

# Cron — protege as rotas /api/cron/** contra chamadas externas não
# autorizadas. A Vercel injeta automaticamente o header
# "Authorization: Bearer <CRON_SECRET>" nas chamadas que ela mesma agenda,
# desde que essa env var esteja configurada no projeto.
CRON_SECRET=

# Render worker (M14) — serviço separado no Railway que renderiza vídeo
# (Remotion). Ver render-worker/README ou docs/CLAUDE.md para o deploy.
# RENDER_WORKER_SECRET precisa ser o MESMO valor configurado no worker
# (render-worker/.env.example) — é o Bearer token que autentica as
# chamadas entre o cron e o worker.
RENDER_WORKER_URL=
RENDER_WORKER_SECRET=

# Cut.Pro (M16) — clipagem por IA + edição de vídeo com o template da casa
# (legendas automáticas embutidas). Gerar em cut.pro > Configurações > API
# (D0, ver docs/plans/2026-07-15-m16-drive-cutpro.md) — confirmar antes que
# o plano contratado não gera vídeo com marca d'água (force_watermark/
# has_watermark na resposta da API).
CUTPRO_API_KEY=
# Só necessária em planos multi-workspace — a maioria dos planos opera sobre
# o workspace padrão da própria chave.
# CUTPRO_WORKSPACE_ID=
# Base real validada em 15/07/2026 (já é o default hardcoded no código —
# só preencher se o Cut.Pro fornecer um ambiente diferente do padrão).
# CUTPRO_API_BASE_URL=https://api.cut.pro/api/v1
